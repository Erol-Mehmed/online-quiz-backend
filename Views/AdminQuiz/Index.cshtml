@model IEnumerable<Quiz>
@{
  ViewData["Title"] = "Manage Quizzes";
}

<h2 class="mb-5">Manage Quizzes</h2>

<a asp-controller="AdminQuiz" asp-action="Create" class="btn btn-primary mb-5">
  Create Quiz
</a>

<table class="table">
  <tr class="border-bottom">
    <th>Title</th>
    <th>Category</th>
  </tr>

  @foreach (var quiz in Model)
  {
    <tr>
      <td>@quiz.Title</td>
      <td>@quiz.Category?.Name</td>
      <td>
        <a asp-action="Edit" asp-route-id="@quiz.Id" class="btn btn-sm btn-primary">Edit</a> |
        <button class="btn btn-sm btn-danger"
                onclick="openDeleteModal('@Url.Action("Delete","AdminQuiz")', @quiz.Id, '@quiz.Title')">
          Delete
        </button>
      </td>
    </tr>
  }
</table>

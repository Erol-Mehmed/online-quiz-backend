@model IEnumerable<Quiz>
@{
  ViewData["Title"] = "Manage Quizzes";
}

<h2>Manage Quizzes</h2>

<a asp-controller="AdminQuiz" asp-action="Create" class="btn btn-primary mb-2">
  Create Quiz
</a>

<table class="table">
  <tr>
    <th>Title</th>
    <th></th>
  </tr>

  @foreach (var quiz in Model)
  {
    <tr>
      <td>@quiz.Title</td>
      <td>
        <a asp-action="Edit" asp-route-id="@quiz.Id">Edit</a> |
        <button class="btn btn-sm btn-danger"
                onclick="openDeleteModal('@Url.Action("Delete","AdminQuiz")', @quiz.Id, '@quiz.Title')">
          Delete
        </button>
      </td>
    </tr>
  }
</table>

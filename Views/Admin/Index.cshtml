@{
  ViewData["Title"] = "Admin Dashboard";
}

<h1 class="mb-4">Admin Dashboard</h1>

<div class="row">
  <!-- Manage Categories -->
  <div class="col-md-6 mb-3">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Categories</h5>
        <p class="card-text">View, create, edit, and delete quiz categories.</p>
        <a class="btn btn-primary" asp-controller="AdminCategory" asp-action="Index">Manage Categories</a>
      </div>
    </div>
  </div>

  <!-- Manage Quizzes -->
  <div class="col-md-6 mb-3">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Quizzes</h5>
        <p class="card-text">View, create, edit, and delete quizzes.</p>
        <a class="btn btn-primary" asp-controller="AdminQuiz" asp-action="Index">Manage Quizzes</a>
      </div>
    </div>
  </div>
</div>

<hr />

<div class="row">
  <div class="col-md-12">
    <div class="alert alert-info">
      Welcome, @User.Identity.Name! Here you can manage your platform content.
    </div>
  </div>
</div>